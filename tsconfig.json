{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "types": ["node", "electron"],
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": [
    "src/extension.ts",
    "src/commands/**/*",
    "src/editor/**/*",
    "src/webview/**/*"
  ]
}
